<Window x:Class="Touch_Panel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:local="clr-namespace:Touch_Panel"
        mc:Ignorable="d"
        Title="TOUCH PANEL SYSTEM" Height="1080" Width="1920" Closing="Window_Closing">

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.7*" />
                <ColumnDefinition Width="10*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="0.7*" />
                <RowDefinition Height="8*" />
                <RowDefinition Height="0.5*" />
            </Grid.RowDefinitions>

            <Image RenderOptions.BitmapScalingMode="HighQuality" Source="../CompanyLogo/TNG Logo.png"/>
            <Image RenderOptions.BitmapScalingMode="HighQuality" Grid.Row="2" Source="../CompanyLogo/Human.png"/>

            <StackPanel Background="{StaticResource BaseBrush}" Grid.Row="1">
                <Button Cursor="Hand" FontSize="20" Margin="0 10" Content="AUTO" Width="100" Height="30" Command="{Binding HomePageCommand}"/>
                <Button Cursor="Hand" FontSize="20" Margin="0 0" Content="MANUAL" Width="100" Height="30" Command="{Binding ManualPageCommand}" />
                    <Button Cursor="Hand" FontSize="20" Margin="0 10" Content="MODEL" Width="100"  Height="30" Command="{Binding NewModelPageCommand}"/>
                <Button Cursor="Hand" FontSize="20" Margin="0 0"  Content="SETTING" Width="100" Height="30" Command="{Binding SettingPageCommand}"/>

                <Label Content="v2.0" Foreground="White" HorizontalContentAlignment="Center" Margin="0, 690, 0, 0"/>
            </StackPanel>

            <Grid Grid.Column="1" >
                <Label Content="TOUCH PANEL SYSTEM" Background="{StaticResource BaseBrush}" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="35"/>
                <StackPanel Margin="5 10"  Orientation="Horizontal" HorizontalAlignment="Right" >
                    <Label Content="{Binding ModelName}" VerticalContentAlignment="Center" Foreground="White"  FontSize="15"/>
                    <Button   FontSize="15"   Padding="5" Height="40" Command="{Binding OpenModelCommand}" Cursor="Hand" Background="Transparent" BorderThickness="0" ToolTip="Import Model">
                        <fa:IconImage Icon="FileUpload" Foreground="Orange" Width="24" Height="24"/>

                    </Button>

                </StackPanel>
            </Grid>

            <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding CurrentPage}" />
            <ContentControl Grid.Row="2" Grid.Column="1" Content="{Binding DeviceConnectionPage}" />
        </Grid>

    </Grid>
</Window>
