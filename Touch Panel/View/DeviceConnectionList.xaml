<UserControl x:Class="Touch_Panel.View.DeviceConnectionList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                            xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"

             xmlns:local="clr-namespace:Touch_Panel.View">
    <Grid   Background="{StaticResource BaseBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <ItemsControl VerticalAlignment="Center" ItemsSource="{Binding Devices.DevicesStatus}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:DeviceConnectionView />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
      
        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label>
                <Label.Content>
                    <StackPanel Orientation="Horizontal">
                        <!--<TextBlock Foreground="White" Text="MAIN:" Margin="5 0"/>-->



                        <!-- TextBlock hiển thị icon hoặc text tùy theo giá trị -->
                        <TextBlock x:Name="DirectionDisplay" Foreground="White" FontSize="20" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <!-- Giá trị mặc định (không phải Down) -->
                                    <Setter Property="Text" Value="{Binding Devices.SystemData.MainDirection}" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Devices.SystemData.MainDirection}" Value="Down">
                                            <Setter Property="Text" Value="↓" />
                                            <!-- hoặc dùng icon font: "" nếu dùng Segoe MDL2 Assets -->
                                            <!-- Nếu muốn icon to hơn: FontSize="20" FontFamily="Segoe MDL2 Assets" -->
                                        </DataTrigger>
                                        
                                        
                                        <DataTrigger Binding="{Binding Devices.SystemData.MainDirection}" Value="Stop">
                                            <Setter Property="Text" Value="" />
                                            <!-- hoặc dùng icon font: "" nếu dùng Segoe MDL2 Assets -->
                                            <!-- Nếu muốn icon to hơn: FontSize="20" FontFamily="Segoe MDL2 Assets" -->
                                        </DataTrigger>


                                        <!-- Có thể thêm trigger khác nếu cần ví dụ cho "Up" là ↑ -->
                                        <DataTrigger Binding="{Binding Devices.SystemData.MainDirection}" Value="Up">
                                            <Setter Property="Text" Value="↑" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Label.Content>
            </Label>
        </StackPanel>
        <StackPanel Grid.Column="1"  Grid.ColumnSpan="2" VerticalAlignment="Center" HorizontalAlignment="Right" Orientation="Horizontal">
            <Label>
                <Label.Content>
                    <StackPanel Orientation="Horizontal">
                      

                        <TextBlock  Foreground="White"  Text="Hex file:" VerticalAlignment="Center"   />
                        <TextBlock Text="{Binding Devices.SelectedFirmwareMicom}" VerticalAlignment="Center" Foreground="Orange" Margin="5 0"/>


                    </StackPanel>
                </Label.Content>
            </Label>
            
            <StackPanel Orientation="Horizontal">
                <Label>
                    <Label.Content>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Microchip" Foreground="White" Width="15" VerticalAlignment="Center" Margin="2 0" />

                            <TextBlock Foreground="White" FontSize="10"  Text="MICOM1 " VerticalAlignment="Center" />

                            <TextBlock  Foreground="White" FontSize="10"   Text="{Binding Devices.MicomData1.FirmwareLog}" VerticalAlignment="Center"   />
                            <TextBlock  Foreground="White" FontSize="10"   Text="{Binding Devices.MicomData1.SignalIntegrity}" VerticalAlignment="Center" Padding="2 0" />


                        </StackPanel>
                    </Label.Content>
                </Label>
                <Label>
                    <Label.Content>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Microchip" Foreground="White" Width="15" VerticalAlignment="Center" Margin="2 0" />

                            <TextBlock Foreground="White" FontSize="10"  Text="MICOM2 " VerticalAlignment="Center" />

                            <TextBlock   Foreground="White" FontSize="10"   Text="{Binding  Devices.MicomData2.FirmwareLog}" VerticalAlignment="Center"   />
                            <TextBlock  Foreground="White" FontSize="10"   Text="{Binding Devices.MicomData2.SignalIntegrity}" VerticalAlignment="Center" Padding="2 0" />

                        </StackPanel>
                    </Label.Content>
                </Label>
            </StackPanel>
            
        </StackPanel>
    </Grid>
</UserControl>
