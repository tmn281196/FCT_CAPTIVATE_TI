<UserControl x:Class="Touch_Panel.View.StepsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
               xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:Touch_Panel.View"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
            >
    <UserControl.Resources>
        <ResourceDictionary>

            <Style x:Key="StatusLabelStyle" TargetType="Label">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Status}" Value="Wait">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="30" />

                        <Setter Property="Background" Value="Orange" />
                        <Setter Property="Content" Value="WAIT" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding Status}" Value="Ready">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="30" />

                        <Setter Property="Background" Value="#347474" />
                        <Setter Property="Content" Value="READY" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding Status}" Value="Testing">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="30" />

                        <Setter Property="Background" Value="#f8da5b" />
                        <Setter Property="Content" Value="TESTING" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding Status}" Value="Pass">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="30" />

                        <Setter Property="Background" Value="LimeGreen" />
                        <Setter Property="Content" Value="PASS" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding Status}" Value="Fail">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="30" />
                        <Setter Property="Background" Value="Red" />
                        <Setter Property="Content" Value="FAIL" />

                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Template.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <Grid  HorizontalAlignment="Stretch" VerticalAlignment="Center" Grid.ColumnSpan="2" Grid.Row="1" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <Button Command="{Binding AddStepCommand}"  CommandParameter="1" BorderThickness="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Left" Margin="5">
                    <StackPanel Orientation="Horizontal" >
                        <fa:IconImage Icon="Add" Foreground="Gray" Width="25"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding DeleteStepCommand}"  CommandParameter="1" BorderThickness="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Left" Margin="5">
                    <StackPanel Orientation="Horizontal" >
                        <fa:IconImage Icon="Trash" Foreground="Gray" Width="25"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding SkipAllStepsCommand}"  CommandParameter="1" BorderThickness="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Left" Margin="5">
                    <StackPanel Orientation="Horizontal" >
                        <fa:IconImage Icon="Square" Foreground="Gray" Width="25"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding UnSkipAllStepsCommand}"  CommandParameter="1" BorderThickness="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Left" Margin="5">
                    <StackPanel Orientation="Horizontal" >
                        <fa:IconImage Icon="CheckSquare" Foreground="Gray" Width="25"/>
                    </StackPanel>
                </Button>
           
            </StackPanel>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Column="1" Grid.RowSpan="2" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
                    <StackPanel Margin="1 0" >
                        <Label Content="CMD Name" HorizontalContentAlignment="Center"/>
                        <ComboBox Padding="0" Height="25" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ItemsSource="{Binding TestList}" SelectedItem="{Binding TestSelItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="123"/>
                    </StackPanel>
                    <StackPanel Margin="1 0" >
                        <Label Content="Time Delay (ms)" HorizontalContentAlignment="Center"/>
                        <TextBox Width="102" Text="{Binding TimeDelayInput, Mode=TwoWay}" Height="25" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="1 0" >
                        <Label Content="Time Test (ms)" HorizontalContentAlignment="Center"/>
                        <TextBox Width="102" Text="{Binding TimeTestInput, Mode=TwoWay}" Height="25" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="1 0" >
                        <Label Content="Object ID" HorizontalContentAlignment="Center"/>
                        <TextBox Width="102" Text="{Binding ObjectIdInput, Mode=TwoWay}" Height="25" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="1 0" >
                        <Label Content="Spec Value" HorizontalContentAlignment="Center"/>
                        <TextBox Width="102" Text="{Binding SpecValueInput, Mode=TwoWay}" Height="25" VerticalContentAlignment="Center"/>
                    </StackPanel>

                </StackPanel>

                <StackPanel  HorizontalAlignment="Center"   Orientation="Vertical"  VerticalAlignment="Bottom" Margin="5 0">
               


                    <StackPanel  Margin="0 0" Orientation="Horizontal">

                        <StackPanel>
                            <Label    HorizontalAlignment="Left" VerticalAlignment="Center"  Padding="0" FontWeight="Bold"  Margin="0 5" >
                                <Label.Content>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                        <TextBlock   Padding="2 0" VerticalAlignment="Center">Firmware</TextBlock>

                                    </StackPanel>
                                </Label.Content>
                            </Label>
                            <ComboBox Width="280" HorizontalAlignment="Center" Height="25" VerticalAlignment="Top"  Margin="2 0 0 2"
ItemsSource="{Binding Model.Devices.FirmwareList}"
 SelectedItem="{Binding Model.Devices.SelectedFirmwareMicom, Mode=TwoWay}"
HorizontalContentAlignment="Left"
VerticalContentAlignment="Center" >

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                            </ComboBox>
                        </StackPanel>



                        <StackPanel>
                            <Label   HorizontalAlignment="Left" VerticalAlignment="Center"  Padding="0" FontWeight="Bold"  Margin="0 5" >
                                <Label.Content>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                        <fa:IconImage Icon="Microchip" Foreground="Black" Width="15" />
                                        <TextBlock   Padding="2 0" VerticalAlignment="Center">MICOM1</TextBlock>

                                    </StackPanel>
                                </Label.Content>
                            </Label>
                            <StackPanel Orientation="Horizontal">
                                <Button  Command="{Binding WriteFirmwareCommand}" Width="70" Height="25" CommandParameter="1"  Cursor="Hand" HorizontalAlignment="Left"  Content="WRITE" Margin="2 0 0 2" Padding="5 0"/>
                                <Button Command="{Binding VerifyFirmwareCommand}" Width="70" Height="25" CommandParameter="1"  Cursor="Hand" HorizontalAlignment="Left"  Content="VERIFY" Margin="2 0 0 2" Padding="5 0"/>

                            </StackPanel>

                        </StackPanel>
                        <StackPanel>
                            <Label    HorizontalAlignment="Left" VerticalAlignment="Center"  Padding="0" FontWeight="Bold"  Margin="0 5" >
                                <Label.Content>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                        <fa:IconImage Icon="Microchip" Foreground="Black" Width="15" />
                                        <TextBlock   Padding="2 0" VerticalAlignment="Center">MICOM2</TextBlock>

                                    </StackPanel>
                                </Label.Content>
                            </Label>
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding WriteFirmwareCommand}"  Width="70" Height="25" CommandParameter="2"  Cursor="Hand" HorizontalAlignment="Left"  Content="WRITE"  Margin="2 0 0 2" Padding="5 0"/>
                                <Button Command="{Binding VerifyFirmwareCommand}"  Width="70" Height="25" CommandParameter="2"  Cursor="Hand" HorizontalAlignment="Left"  Content="VERIFY"  Margin="2 0 0 2" Padding="5 0"/>

                            </StackPanel>
                        </StackPanel>


                    </StackPanel>



                </StackPanel>
               
               
            </StackPanel>


            



            <StackPanel   Orientation="Horizontal" Grid.Column="2"  HorizontalAlignment="Right">
                <Button Command="{Binding UnSkipAllStepsCommand}"  CommandParameter="2" BorderThickness="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Left" Margin="5">
                    <StackPanel Orientation="Horizontal" >
                        <fa:IconImage Icon="CheckSquare" Foreground="Gray" Width="25"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding SkipAllStepsCommand}"  CommandParameter="2" BorderThickness="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Left" Margin="5">
                    <StackPanel Orientation="Horizontal" >
                        <fa:IconImage Icon="Square" Foreground="Gray" Width="25"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding AddStepCommand}"  CommandParameter="2" BorderThickness="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Right" Margin="5">
                    <StackPanel Orientation="Horizontal" >
                        <fa:IconImage Icon="Add" Foreground="Gray" Width="25"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding DeleteStepCommand}"  CommandParameter="2" BorderThickness="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Right" Margin="5">
                    <StackPanel Orientation="Horizontal" >
                        <fa:IconImage Icon="Trash" Foreground="Gray" Width="25"/>
                    </StackPanel>
                </Button>
            </StackPanel>



            <Button Command="{Binding SaveModelCommand}" BorderThickness="0" Margin="5 5"  Padding="5 0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Center" Grid.Row="1" Grid.Column="2">
                <StackPanel Orientation="Horizontal" >
                    <fa:IconImage Icon="Save" Foreground="Orange" Width="20"/>
                    <Label Foreground="Black" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold" FontSize="15">SAVE</Label>

                </StackPanel>
            </Button>



        </Grid>




        <StackPanel Grid.Column="0" >

            <DataGrid Height="800" VerticalScrollBarVisibility="Visible"  ItemsSource="{Binding Model.Micom1TestStep.Steps, UpdateSourceTrigger=PropertyChanged}" SelectedIndex="{Binding StepSelIdx1}" SelectedItem="{Binding StepSelItem1}" Background="White" Style="{StaticResource CustomDataGridStyle}"
  ColumnHeaderStyle="{StaticResource CustomDataGridHeaderStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding No}" Width="50" Header="No" />
                    <DataGridTextColumn Binding="{Binding Test}" Width="*" Header="CMD Name" />
                    <DataGridTextColumn Binding="{Binding Timedelay}" Width="*" Header="Time Delay" />
                    <DataGridTextColumn Binding="{Binding Timetest}" Width="*" Header="Time Test" />

                    <DataGridTextColumn Binding="{Binding Objectid}" Width="*" Header="Object ID" />
                    <DataGridTextColumn Binding="{Binding Specvalue}" Width="*" Header="Spec Value" />

                    <DataGridCheckBoxColumn Header="Enable" Binding="{Binding NoSkip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  Width="*" />
                </DataGrid.Columns>


            </DataGrid>

        </StackPanel>

        <StackPanel Grid.Column="1" >
            <DataGrid Height="800"  VerticalScrollBarVisibility="Visible"  ItemsSource="{Binding Model.Micom2TestStep.Steps, UpdateSourceTrigger=PropertyChanged}" SelectedIndex="{Binding StepSelIdx2}" SelectedItem="{Binding StepSelItem2}" Background="White" Style="{StaticResource CustomDataGridStyle}"
ColumnHeaderStyle="{StaticResource CustomDataGridHeaderStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding No, UpdateSourceTrigger=PropertyChanged}" Width="50" Header="No" />
                    <DataGridTextColumn Binding="{Binding Test, UpdateSourceTrigger=PropertyChanged}" Width="*"  Header="CMD Name" />
                    <DataGridTextColumn Binding="{Binding Timedelay, UpdateSourceTrigger=PropertyChanged}" Width="*"  Header="Time Delay" />
                    <DataGridTextColumn Binding="{Binding Timetest, UpdateSourceTrigger=PropertyChanged}" Width="*"  Header="Time Test" />

                    <DataGridTextColumn Binding="{Binding Objectid, UpdateSourceTrigger=PropertyChanged}" Width="*"  Header="Object ID" />
                    <DataGridTextColumn Binding="{Binding Specvalue, UpdateSourceTrigger=PropertyChanged}" Width="*"  Header="Spec Value" />
                    <DataGridCheckBoxColumn Header="Enable" Binding="{Binding NoSkip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  Width="*" />
                </DataGrid.Columns>



            </DataGrid>


        </StackPanel>
    </Grid>
</UserControl>
