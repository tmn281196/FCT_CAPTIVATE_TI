<UserControl x:Class="Touch_Panel.View.SettingPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                      xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"

             xmlns:local="clr-namespace:Touch_Panel.View">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Vertical"  Grid.ColumnSpan="2" >
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5"> 
                <Label HorizontalAlignment="Center" Content="Log Directory" Width="100" FontWeight="Bold"/>

                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox   Text="{Binding Model.Settings.LogDir, Mode=OneWay}" IsReadOnly="True" x:Name="mesDirTxtBox" Width="500" Padding="0 2" VerticalAlignment="Center" />
                    <Button x:Name="changeMesDirBtn" Command="{Binding ChangeToNewLogDirCommand}" BorderThickness="0"  Width="24" Height="24" Background="Transparent" Cursor="Hand">
                        <fa:IconImage Icon="File" Foreground="Orange"/>
                    </Button>
                </StackPanel>

            </StackPanel>
    

            <!--<Label HorizontalAlignment="Center" Content="Value Minimum Offset" />-->
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <!--<TextBox Text="{Binding Model.Settings.Offset}"  Margin="0, 0, 10, 0" Width="50" Height="20"  />-->
            </StackPanel>
            <Separator/>


            <StackPanel  Orientation="Vertical">
          
                <StackPanel Margin="5">
                    <StackPanel Margin="0 5" Orientation="Horizontal">
                        <Label Content="Micom 1" Width="70"/>
                        <ComboBox  HorizontalContentAlignment="Left" SelectedItem="{Binding Model.Devices.MicomCom1Port}" ItemsSource="{Binding Model.Devices.ComPortList}" Width="100"/>
                        <Button Width="80" Content="Connect" Command="{Binding DeviceConnectCommand}" CommandParameter="Micom1" Margin="10, 0" Cursor="Hand"/>
                    </StackPanel>
                    <StackPanel Margin="0 5" Orientation="Horizontal">
                        <Label Content="Micom 2" Width="70"/>
                        <ComboBox HorizontalContentAlignment="Left" SelectedItem="{Binding Model.Devices.MicomCom2Port}" ItemsSource="{Binding Model.Devices.ComPortList}" Width="100"/>
                        <Button Width="80" Content="Connect" Command="{Binding DeviceConnectCommand}" CommandParameter="Micom2" Margin="10, 0" Cursor="Hand"/>
                    </StackPanel>
                    <StackPanel Margin="0 5" Orientation="Horizontal">
                        <Label Content="System" Width="70"/>
                        <ComboBox  HorizontalContentAlignment="Left" SelectedItem="{Binding Model.Devices.SystemComPort}" ItemsSource="{Binding Model.Devices.ComPortList}" Width="100"/>
                        <Button Width="80" Content="Connect" Command="{Binding DeviceConnectCommand}"  CommandParameter="System" Margin="10, 0" Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Margin="0 5" Orientation="Horizontal">
                        <Label Content="Solenoid 1" Width="70"/>
                        <ComboBox HorizontalContentAlignment="Left" SelectedItem="{Binding Model.Devices.Solenoid1ComPort}" ItemsSource="{Binding Model.Devices.ComPortList}" Width="100"/>
                        <Button Width="80" Content="Connect" Command="{Binding DeviceConnectCommand}"  CommandParameter="Solenoid 1" Margin="10, 0" Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Margin="0 5" Orientation="Horizontal">
                        <Label Content="Solenoid 2" Width="70"/>
                        <ComboBox HorizontalContentAlignment="Left" SelectedItem="{Binding Model.Devices.Solenoid2ComPort}" ItemsSource="{Binding Model.Devices.ComPortList}" Width="100"/>
                        <Button Width="80" Content="Connect" Command="{Binding DeviceConnectCommand}" CommandParameter="Solenoid 2" Margin="10, 0" Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Margin="0 5" Orientation="Horizontal">
                        <Label Content="Solenoid 3" Width="70"/>
                        <ComboBox HorizontalContentAlignment="Left" SelectedItem="{Binding Model.Devices.Solenoid3ComPort}" ItemsSource="{Binding Model.Devices.ComPortList}" Width="100"/>
                        <Button Width="80" Content="Connect" Command="{Binding DeviceConnectCommand}"  CommandParameter="Solenoid 2" Margin="10, 0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
                <Button Command="{Binding RefreshComportCommand}" HorizontalAlignment="Left" Width="24" Height="24" Margin="10 0" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Enumerate COM Ports">
                    <fa:IconImage Icon="Refresh" Foreground="Black" />

                </Button>
            </StackPanel>
            <Separator/>

            <StackPanel  Margin="5">
                <StackPanel Margin="0 5" Orientation="Horizontal">
                    <Label Content="Delay Before Test Begin (ms)" />
                    <TextBox HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="50" Padding="2 2" Text="{Binding Model.Settings.DelayBeforeTestBegin}"/>
                </StackPanel>
                <CheckBox  Margin="0 5"  Content="Reset Cylinder When Test Pass" IsChecked="{Binding Model.Devices.EnableResetCylinder}"/>
                <CheckBox  Margin="0 5"  Content="Should Stop All When Any Failed Step" IsChecked="{Binding Model.Settings.ShouldStopAllWhenAnyFailedStep}"/>

            </StackPanel>
            
            

            <Separator></Separator>


            <Button Command="{Binding SaveCommand}" BorderThickness="0"  Width="100" Background="Transparent" Cursor="Hand" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" >
                    <fa:IconImage Icon="Save" Foreground="Orange" Width="25"/>
                    <Label Foreground="Black" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold" FontSize="20">SAVE</Label>

                </StackPanel>
            </Button>


        </StackPanel>




    </Grid>
</UserControl>
