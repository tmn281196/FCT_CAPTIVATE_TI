<UserControl x:Class="Touch_Panel.View.AutoPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                      xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"

             xmlns:local="clr-namespace:Touch_Panel.View"
             >
    <UserControl.Resources>
        <ResourceDictionary>

            <Style x:Key="StatusLabelStyle" TargetType="Label">
                <Style.Triggers>

               
                    
                    <DataTrigger Binding="{Binding Status}" Value="Wait">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="20" />

                        <Setter Property="Background" Value="Orange" />
                        <Setter Property="Content" Value="WAIT" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding Status}" Value="Ready">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="20" />

                        <Setter Property="Background" Value="#347474" />
                        <Setter Property="Content" Value="READY" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding Status}" Value="Testing">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="20" />

                        <Setter Property="Background" Value="#f8da5b" />
                        <Setter Property="Content" Value="TESTING" />

                    </DataTrigger>

                    <!--<DataTrigger Binding="{Binding Status}" Value="Pass">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="20" />

                        <Setter Property="Background" Value="LimeGreen" />
                        <Setter Property="Content" Value="PASS" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding Status}" Value="Fail">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="20" />
                        <Setter Property="Background" Value="Red" />
                        <Setter Property="Content" Value="FAIL" />

                    </DataTrigger>-->
                    <DataTrigger Binding="{Binding Status}" Value="Stop">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="20" />

                        <Setter Property="Background" Value="Black" />
                        <Setter Property="Content" Value="STOP" />

                    </DataTrigger>

                </Style.Triggers>
            </Style>

            <Style x:Key="TestResultLabelStyle" TargetType="Label">
                <Style.Triggers>

                    <DataTrigger Binding="{Binding StringTestResult}" Value="">
                        <Setter Property="Foreground" Value="Beige" />
                        <Setter Property="FontSize" Value="30" />

                        <Setter Property="Background" Value="LightBlue" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding StringTestResult}" Value="Pass">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="30" />

                        <Setter Property="Background" Value="LimeGreen" />
                        <Setter Property="Content" Value="PASS" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding StringTestResult}" Value="Fail">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontSize" Value="30" />
                        <Setter Property="Background" Value="Red" />
                        <Setter Property="Content" Value="FAIL" />
                    </DataTrigger>
                 

                </Style.Triggers>
            </Style>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Template.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <Grid Grid.ColumnSpan="3" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>    
            </Grid.ColumnDefinitions>
            <DataGrid IsReadOnly="True" SelectedIndex="{Binding TestLogic.Tester1.CurrStep}"  SelectionChanged="DataGrid_SelectionChanged"  ItemsSource="{Binding Model.Step1.Steps}" Background="White" Style="{StaticResource CustomDataGridStyle}" Grid.Column="0"
    ColumnHeaderStyle="{StaticResource CustomDataGridHeaderStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding No}" Width="50" Header="No" />
                    <DataGridTextColumn Binding="{Binding Test}" Width="*"  Header="CMD Name" />
                    <DataGridTextColumn Binding="{Binding Objectid}" Width="*"  Header="Object ID" />
                    <DataGridTextColumn Binding="{Binding Specvalue}" Width="*"  Header="Spec Value" />
                    <DataGridTextColumn Binding="{Binding Value}" Width="100"  Header="Value" />
                    <DataGridTemplateColumn Width="80" Header="Result">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <fa:IconBlock Width="20" Height="20" FontSize="18"  VerticalAlignment="Center"  HorizontalAlignment="Center">
                                    <fa:IconBlock.Style>
                                        <Style TargetType="fa:IconBlock">
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Setter Property="Icon" Value="Circle"/>

                                            <Style.Triggers>
                                                <!-- SKIP -->
                                                <DataTrigger Binding="{Binding Result}" Value="Skip">
                                                    <Setter Property="Icon" Value="CircleChevronRight"/>
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                </DataTrigger>

                                                <!-- PASS -->
                                                <DataTrigger Binding="{Binding Result}" Value="Pass">
                                                    <Setter Property="Icon" Value="CircleCheck"/>
                                                    <Setter Property="Foreground" Value="LimeGreen"/>
                                                </DataTrigger>

                                                <!-- FAIL -->
                                                <DataTrigger Binding="{Binding Result}" Value="Fail">
                                                    <Setter Property="Icon" Value="CircleXmark"/>
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </fa:IconBlock.Style>
                                </fa:IconBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid IsReadOnly="True" SelectedIndex="{Binding TestLogic.Tester2.CurrStep}"  SelectionChanged="DataGrid_SelectionChanged"  ItemsSource="{Binding Model.Step2.Steps}" Background="White" Style="{StaticResource CustomDataGridStyle}" Grid.Column="1"
    ColumnHeaderStyle="{StaticResource CustomDataGridHeaderStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding No}" Width="50" Header="No" />
                    <DataGridTextColumn Binding="{Binding Test}" Width="*"  Header="CMD Name" />
                    <DataGridTextColumn Binding="{Binding Objectid}" Width="*"  Header="Object ID" />
                    <DataGridTextColumn Binding="{Binding Specvalue}" Width="*"  Header="Spec Value" />
                    <DataGridTextColumn Binding="{Binding Value}" Width="100"  Header="Value" />
                    <DataGridTemplateColumn Width="80" Header="Result">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <fa:IconBlock Width="20" Height="20" FontSize="18"  VerticalAlignment="Center"  HorizontalAlignment="Center">
                                    <fa:IconBlock.Style>
                                        <Style TargetType="fa:IconBlock">
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Setter Property="Icon" Value="Circle"/>

                                            <Style.Triggers>
                                                <!-- SKIP -->
                                                <DataTrigger Binding="{Binding Result}" Value="Skip">
                                                    <Setter Property="Icon" Value="CircleChevronRight"/>
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                </DataTrigger>

                                                <!-- PASS -->
                                                <DataTrigger Binding="{Binding Result}" Value="Pass">
                                                    <Setter Property="Icon" Value="CircleCheck"/>
                                                    <Setter Property="Foreground" Value="LimeGreen"/>
                                                </DataTrigger>

                                                <!-- FAIL -->
                                                <DataTrigger Binding="{Binding Result}" Value="Fail">
                                                    <Setter Property="Icon" Value="CircleXmark"/>
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </fa:IconBlock.Style>
                                </fa:IconBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
       
        
        </Grid>

        

        <StackPanel Grid.Row="1" Grid.Column="1" >
            <Label HorizontalContentAlignment="Center" Content="Elapsed Time" Foreground="White" Background="{StaticResource BaseBrush}" />
            <Label Content="{Binding ElapsedTime}" FontWeight="Bold" FontSize="20" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"  x:Name="elapsedTimeLbl"  Background="White" Height="120" />

        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0.5, 0" >
            <Label HorizontalContentAlignment="Center" Content="Status" Foreground="White" Background="{StaticResource BaseBrush}" />
            <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="40" Style="{StaticResource StatusLabelStyle}" />
            <Label   HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="80" Style="{StaticResource TestResultLabelStyle}" />
        </StackPanel>

      
        <Grid Grid.Row="1">

            <!-- Chia layout theo chiều dọc -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Label Grid.Row="0"
           Content="Statistics"
           HorizontalContentAlignment="Center"
           Foreground="White"
           Background="{StaticResource BaseBrush}" />

            <!-- Nội dung căn giữa theo chiều dọc -->
            <Grid Grid.Row="1"
          VerticalAlignment="Center"
          HorizontalAlignment="Center">

                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                    <!-- Button -->

                    <StackPanel Orientation="Horizontal">
                        <Button Background="Transparent" BorderThickness="0" Padding="5 0" Margin="2"  FontSize="16" Height="50" Width="50"  Cursor="Hand" Command="{Binding ForceStartCommand}"   HorizontalContentAlignment="Center">
                            <fa:IconImage Icon="CirclePlay" Foreground="Lime"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="5 0" Margin="2"  FontSize="16" Height="50" Width="50"  Cursor="Hand" Command="{Binding ForceStopCommand}"   HorizontalContentAlignment="Center">
                            <fa:IconImage Icon="CircleStop" Foreground="Red"/>
                        </Button>

                    </StackPanel>
     


                    <!-- Statistics -->
                    <StackPanel Orientation="Horizontal">

                        <StackPanel Width="200"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                            <Label Content="TOTAL"
                           FontSize="20"
                           Background="White"
                           HorizontalContentAlignment="Center" />
                            <Label Content="{Binding Total}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Background="White"
                           HorizontalContentAlignment="Center" />
                        </StackPanel>

                        <StackPanel Width="200"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                            <Label Content="PASS"
                           FontSize="20"
                           Foreground="Green"
                           Background="White"
                           HorizontalContentAlignment="Center" />
                            <Label Content="{Binding Pass}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="Green"
                           Background="White"
                           HorizontalContentAlignment="Center" />
                        </StackPanel>

                        <StackPanel Width="200"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                            <Label Content="NG"
                           FontSize="20"
                           Foreground="Red"
                           Background="White"
                           HorizontalContentAlignment="Center" />
                            <Label Content="{Binding Fail}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="Red"
                           Background="White"
                           HorizontalContentAlignment="Center" />
                        </StackPanel>

                        <StackPanel Width="200"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                            <Label Content="PASS %"
                           FontSize="20"
                           Foreground="DarkGoldenrod"
                           Background="White"
                           HorizontalContentAlignment="Center" />
                            <Label Content="{Binding PassPercent}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="DarkGoldenrod"
                           Background="White"
                           HorizontalContentAlignment="Center" />
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </Grid>
        </Grid>

    </Grid>

</UserControl>
